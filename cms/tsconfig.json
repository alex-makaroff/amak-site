{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "outDir": "dist",
    "noEmit": true
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "build", "dist"]
}
