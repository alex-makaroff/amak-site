{
  "kind": "collectionType",
  "collectionName": "cases",
  "info": {
    "singularName": "case",
    "pluralName": "cases",
    "displayName": "Case",
    "description": "Portfolio case"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["website", "design"],
      "required": true
    },
    "badge": {
      "type": "string",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "description": {
      "type": "richtext"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "coverAlt": {
      "type": "string"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "featuredRank": {
      "type": "integer"
    },
    "sortRank": {
      "type": "integer"
    },
    "details": {
      "type": "dynamiczone",
      "components": [
        "case.website-details",
        "case.design-details"
      ],
      "required": true,
      "max": 1,
      "min": 1
    }
  }
}
